{
  "name": "cjvibe",
  "version": "0.1.3",
  "description": "CLI tool for syncing with self-hosted Confluence and Jira",
  "bin": {
    "cjvibe": "./bin/cjvibe.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --compile --outfile dist/cjvibe",
    "link": "bun link",
    "typecheck": "bunx tsc --noEmit",
    "bump": "bun scripts/bump.ts patch",
    "bump:patch": "bun scripts/bump.ts patch",
    "bump:minor": "bun scripts/bump.ts minor",
    "bump:major": "bun scripts/bump.ts major"
  },
  "devDependencies": {
    "@types/node": "latest",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [],
  "private": true,
  "dependencies": {
    "htmlparser2": "^10.1.0"
  }
}
